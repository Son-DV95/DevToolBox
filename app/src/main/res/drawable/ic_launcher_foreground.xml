<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Hexagonal Tech Shield Outer Glow -->
    <path
        android:pathData="M 54,24 L 83,40 L 83,68 L 54,84 L 25,68 L 25,40 Z"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#151D30"
        android:fillAlpha="0.85">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="25"
                android:startY="24"
                android:endX="83"
                android:endY="84"
                android:type="linear">
                <item android:offset="0.0" android:color="#2DD4BF" /> <!-- Tech Teal -->
                <item android:offset="1.0" android:color="#818CF8" /> <!-- Electric Indigo -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Hexagon Accent Line -->
    <path
        android:pathData="M 54,29 L 78,43 L 78,65 L 54,79 L 30,65 L 30,43 Z"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="30"
                android:startY="29"
                android:endX="78"
                android:endY="79"
                android:type="linear">
                <item android:offset="0.0" android:color="#818CF8" />
                <item android:offset="1.0" android:color="#2DD4BF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Coding Slash Tag (/) -->
    <path
        android:pathData="M 58,41 L 50,67"
        android:strokeWidth="3.5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="58"
                android:startY="41"
                android:endX="50"
                android:endY="67"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFFFFF" />
                <item android:offset="1.0" android:color="#2DD4BF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Coding Left Bracket (<) -->
    <path
        android:pathData="M 45,45 L 37,54 L 45,63"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="45"
                android:startY="45"
                android:endX="37"
                android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFFFFF" />
                <item android:offset="1.0" android:color="#2DD4BF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Coding Right Bracket (>) -->
    <path
        android:pathData="M 63,45 L 71,54 L 63,63"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="63"
                android:startY="45"
                android:endX="71"
                android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFFFFF" />
                <item android:offset="1.0" android:color="#818CF8" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Corner Dots representing Diagnostics / CPU Cores -->
    <path
        android:pathData="M 54,17 A 2,2 0 1 1 53.99,17 Z"
        android:fillColor="#2DD4BF" />
    <path
        android:pathData="M 89,37 A 2,2 0 1 1 88.99,37 Z"
        android:fillColor="#818CF8" />
    <path
        android:pathData="M 89,71 A 2,2 0 1 1 88.99,71 Z"
        android:fillColor="#2DD4BF" />
    <path
        android:pathData="M 54,91 A 2,2 0 1 1 53.99,91 Z"
        android:fillColor="#818CF8" />
    <path
        android:pathData="M 19,71 A 2,2 0 1 1 18.99,71 Z"
        android:fillColor="#2DD4BF" />
    <path
        android:pathData="M 19,37 A 2,2 0 1 1 18.99,37 Z"
        android:fillColor="#818CF8" />

</vector>
